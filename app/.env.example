# .env.example
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to GitHub.

# ── Moralis (primary indexer) ─────────────────────────────────────────────────
# Free tier: https://moralis.io
# Supports comma-separated keys for daily quota rotation (e.g. key1,key2,key3)
MORALIS_API_KEY=your_moralis_key_here

# ── Alchemy (alternate indexer) ───────────────────────────────────────────────
# Free tier: https://alchemy.com — 30M CU/month
# Used as fallback if Moralis quota is exhausted
ALCHEMY_API_KEY=your_alchemy_key_here

# ── Neynar (Farcaster / Base App social) ──────────────────────────────────────
# Free tier: https://neynar.com
NEYNAR_API_KEY=your_neynar_key_here

# ── OpenAI (AI roasts) ────────────────────────────────────────────────────────
# Optional — app falls back to template roasts if not set
# Model: gpt-4o-mini (cheapest, fast enough)
OPENAI_API_KEY=your_openai_key_here

# ── App URL ────────────────────────────────────────────────────────────────────
# Your deployed Vercel URL — used in OG meta tags
NEXT_PUBLIC_URL=https://your-app.vercel.app
